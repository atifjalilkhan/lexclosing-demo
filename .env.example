# Copy this file to .env and fill in real values before running the server.
# .env is gitignored — never commit real secrets.

# --- Database -------------------------------------------------------------
# Recommended for BOTH local development and production: point this at a
# free Supabase project (supabase.com — no credit card required to start).
# Get the connection string from: Project Settings -> Database ->
# Connection string -> "URI".
#
# Which pooler to use depends on where this is running:
#   - Local dev and Render (one long-lived process): "Session pooler",
#     port 5432 — e.g. postgres.YOUR-REF@aws-0-...pooler.supabase.com:5432
#   - Vercel (serverless — many short-lived function instances, each with
#     its own small connection pool): "Transaction pooler", port 6543
#     instead. See the "Deploying a free demo on Vercel" section of
#     README.md.
#
# Using Supabase even during local development means your dev environment
# and your production environment are the exact same database config —
# nothing to change when you deploy — and it avoids needing to install and
# run a local Postgres server at all, which matters if you're developing
# on a machine that's already running other memory-hungry services.
DATABASE_URL=postgres://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
PGSSL=true

# --- Alternative: local Postgres (no internet dependency, but uses local
# RAM and needs Postgres installed) --------------------------------------
# DATABASE_URL=postgres://rwhm_app:some_local_password@localhost:5432/rwhm_intake
# PGSSL=false

# --- Sessions ---------------------------------------------------------
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# --- Server -------------------------------------------------------------
# Kept off 3000-3022 by default in case other local projects use that range.
PORT=4000
NODE_ENV=development

# --- Seed script (backend/seed.js) — creates the first staff login -------
SEED_ADMIN_EMAIL=admin@rwhm.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=RWHM Admin

# --- Staff email notifications (optional; leave blank to skip) -----------
# Free tier at resend.com covers a small firm's intake volume.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=intake@rwhm.com
NOTIFY_TO_EMAIL=

# --- White-labeling for a different firm (optional) ----------------------
# Leave unset to use the RWHM defaults baked into backend/firm-config.js.
# FIRM_NAME=Example Firm, LLP
# FIRM_SHORT_NAME=EF
# FIRM_TAGLINE=Client Intake & Case Status
# CASE_NUMBER_PREFIX=EF
# BRAND_PRIMARY_COLOR=#1b3a2e
# BRAND_ACCENT_COLOR=#b8863e
# BRAND_BACKGROUND_COLOR=#f7f4ee
